<Window x:Class="ImageCompressor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="ImageCompressor 1.1"
        Height="800" Width="1300"
        WindowStartupLocation="CenterScreen"
         ResizeMode="CanResize"
        Background="#f8fafc"
        Foreground="#1e293b"
        FontFamily="Segoe UI, Microsoft YaHei, sans-serif">

    <Window.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Color Palette - Light Theme -->
        <SolidColorBrush x:Key="BackgroundBase" Color="#f8fafc"/>
        <SolidColorBrush x:Key="CardBackground" Color="#ffffff"/>
        <SolidColorBrush x:Key="BorderColor" Color="#e2e8f0"/>
        <SolidColorBrush x:Key="PrimaryColor" Color="#3b82f6"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="#2563eb"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#10b981"/>
        <SolidColorBrush x:Key="WarningColor" Color="#f59e0b"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#ef4444"/>
        <SolidColorBrush x:Key="TextMain" Color="#1e293b"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748b"/>
        <SolidColorBrush x:Key="TextLight" Color="#94a3b8"/>
        <SolidColorBrush x:Key="HoverBackground" Color="#f1f5f9"/>

        <!-- Shadows -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="12" ShadowDepth="0" Color="#000000" Opacity="0.08"/>
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="8" ShadowDepth="2" Color="#3b82f6" Opacity="0.2"/>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="32,0,32,0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHover}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1d4ed8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Width" Value="60"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0,16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBackground}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0,16,0"/>
            <Setter Property="Background" Value="#ef4444"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#dc2626"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#b91c1c"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Text Styles -->
        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="BodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>

        <Style x:Key="SmallTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
        </Style>

        <!-- Input Style -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0,0,0,0" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                    <Setter Property="Background" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Radio Button Style -->
        <Style x:Key="RadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ComboBox Item Style -->
        <Style x:Key="ComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <ContentPresenter VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                Margin="12,0,12,0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBackground}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBackground}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Drop Zone Style -->
        <Style x:Key="DropZoneStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="24"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="图片压缩工具" Style="{StaticResource TitleStyle}"/>
            <TextBlock Text="专业级图片压缩解决方案" Style="{StaticResource SmallTextStyle}"/>
        </StackPanel>

        <!-- Top Zone: Thumbnail List + Preview -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Thumbnail List -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Thumbnail List Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="AddFilesButton" Content="添加图片"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="32" Width="80" Click="BrowseFilesButton_Click"/>
                        <Button x:Name="AddFolderButton" Content="添加文件夹"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="32" Width="90" Margin="8,0,0,0" Click="OpenDirectoryButton_Click"/>
                        <Button x:Name="ClearAllButton" Content="清空"
                                Style="{StaticResource DangerButtonStyle}"
                                Height="32" Width="60" Margin="8,0,0,0" Click="ClearButton_Click"/>
                        <TextBlock x:Name="LoadingStatusText"
                                   Text="{Binding LoadingStatus}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- Thumbnail List -->
                    <Grid Grid.Row="1" x:Name="ThumbnailGrid" AllowDrop="True">
                        <ListBox x:Name="ThumbnailListBox"
                                 ItemsSource="{Binding Images}"
                                 SelectedItem="{Binding SelectedImage}"
                                 SelectionMode="Single"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Width" Value="140"/>
                                    <Setter Property="Height" Value="180"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Margin" Value="0,0,8,8"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource HoverBackground}"
                                            CornerRadius="6"
                                            Padding="8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" Background="{StaticResource BorderColor}"
                                                    CornerRadius="4" Margin="0,0,0,6">
                                                <Grid>
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                    <Button Content="×"
                                                            Width="20" Height="20"
                                                            FontSize="14"
                                                            Foreground="{StaticResource TextMuted}"
                                                            Background="#80FFFFFF"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="4"
                                                            Click="RemoveImage_Click"
                                                            Tag="{Binding}"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}"
                                                           FontSize="11" FontWeight="500"
                                                           Foreground="{StaticResource TextMain}"
                                                           HorizontalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                                                <TextBlock Text="{Binding FileSizeDisplay}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource TextMuted}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,1,0,0"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" HorizontalAlignment="Center"
                                                            Visibility="{Binding HasCompressedVersion, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding StatusText}"
                                                               FontSize="10" FontWeight="500"
                                                               Foreground="{Binding StatusColor}"/>
                                                    <TextBlock Text="{Binding CompressedSizeDisplay, StringFormat=' ({0})'}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource TextMuted}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <!-- Empty State Placeholder -->
                        <StackPanel x:Name="EmptyStatePanel"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding HasNoImages, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Viewbox Width="64" Height="64" Margin="0,0,0,16">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M12.9,14.5L15.8,19H14L12,15.6L10,19H8.2L11.1,14.5L8.2,10H10L12,13.4L14,10H15.8L12.9,14.5Z"
                                          Fill="{StaticResource TextLight}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="拖放图片到此处"
                                       FontSize="16" FontWeight="500"
                                       Foreground="{StaticResource TextMuted}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="或点击上方「添加图片」按钮"
                                       FontSize="12"
                                       Foreground="{StaticResource TextLight}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Right: Preview Panel -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Preview Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="ZoomInButton" Content="+"
                                Width="32" Height="32" FontSize="16"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                        <Button x:Name="ZoomOutButton" Content="-"
                                Width="32" Height="32" FontSize="16"
                                Style="{StaticResource SecondaryButtonStyle}"
                                 Margin="4,0,0,0"/>
                        <Button x:Name="ResetZoomButton" Content="重置"
                                Width="48" Height="32"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="4,0,0,0"/>
                    </StackPanel>

                    <!-- Preview Image -->
                    <Border Grid.Row="1" Background="{StaticResource HoverBackground}"
                            CornerRadius="4">
                        <Grid x:Name="PreviewContainer">
                            <Image x:Name="PreviewImage"
                                   Source="{Binding SelectedImage.OriginalImage}"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock x:Name="PreviewPlaceholder"
                                       Text="选择图片以预览"
                                       FontSize="14"
                                       Foreground="{StaticResource TextLight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Preview Metadata -->
                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <TextBlock x:Name="PreviewFileName"
                                   FontSize="13" FontWeight="600"
                                   Foreground="{StaticResource TextMain}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock x:Name="PreviewFileSize"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text=" • "
                                       FontSize="11"
                                       Foreground="{StaticResource TextLight}"/>
                            <TextBlock x:Name="PreviewDimensions"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom: Tools Panel -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Compression Settings -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="压缩设置" Style="{StaticResource SubtitleStyle}" Margin="0,0,0,12"/>

                    <!-- Target Size -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="目标大小"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SmallTextStyle}"/>

                        <ComboBox x:Name="TargetSizeComboBox" Grid.Column="1" Height="36"
                                  FontSize="13" FontWeight="500" Foreground="{StaticResource TextMain}"
                                  BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                  Background="Transparent" Padding="12,0,12,0"
                                  VerticalContentAlignment="Center"
                                  ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                                  SelectionChanged="TargetSizeComboBox_SelectionChanged">
                            <ComboBoxItem Content="100 KB" Tag="100" IsSelected="True"/>
                            <ComboBoxItem Content="200 KB" Tag="200"/>
                            <ComboBoxItem Content="500 KB" Tag="500"/>
                            <ComboBoxItem Content="1 MB" Tag="1024"/>
                            <ComboBoxItem Content="2 MB" Tag="2048"/>
                            <ComboBoxItem Content="5 MB" Tag="5120"/>
                            <ComboBoxItem Content="自定义..." Tag="custom"/>
                        </ComboBox>

                        <TextBox x:Name="CustomSizeTextBox" Grid.Column="2" Width="130" Height="40"
                                 Style="{StaticResource InputStyle}"
                                 Visibility="Collapsed" TextChanged="CustomSizeTextBox_TextChanged"/>
                    </Grid>

                    <!-- Compression Mode -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton x:Name="CompressionModeBest" Content="极致压缩"
                                     Style="{StaticResource RadioButtonStyle}"
                                     GroupName="Mode" IsChecked="True" Click="CompressionModeBest_Click"/>
                        <RadioButton x:Name="CompressionModeGood" Content="高质量压缩"
                                     Style="{StaticResource RadioButtonStyle}"
                                     GroupName="Mode" Click="CompressionModeGood_Click"/>
                    </StackPanel>

                    <!-- Output Path -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="输出路径"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SmallTextStyle}"/>

                        <TextBox x:Name="OutputPathTextBox" Grid.Column="1" Height="36"
                                 FontSize="12" FontWeight="500"
                                 Foreground="{StaticResource TextMain}"
                                 BorderBrush="{StaticResource BorderColor}"
                                 VerticalContentAlignment="Center"
                                 BorderThickness="1" Background="Transparent" Padding="10,0,10,0"
                                 TextChanged="OutputPathTextBox_TextChanged"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button x:Name="SelectOutputPathButton" Content="浏览"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="4,0,4,0" Height="36" Click="SelectOutputPath_Click"/>
                            <Button x:Name="OpenOutputPathButton" Content="打开"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="36" Click="OpenOutputPath_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="16,0,0,0">
                    <Button x:Name="CompressButton" Style="{StaticResource PrimaryButtonStyle}"
                            Content="开始压缩" Click="CompressButton_Click" Width="120"
                            IsEnabled="{Binding IsNotLoading}"/>
                    <Button x:Name="ExportPdfButton" Style="{StaticResource SecondaryButtonStyle}"
                            Content="导出PDF" Width="100" Height="44" Margin="8,0,0,0" Click="ExportPdfButton_Click"
                            IsEnabled="{Binding IsNotLoading}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>